{
  "mcpServers": {
    "lightarchitects": {
      "command": "${LIGHTARCHITECTS_BIN}",
      "env": {
        "RUST_LOG": "info",
        "OLLAMA_API_KEY": "${OLLAMA_API_KEY}",
        "OLLAMA_TIMEOUT": "15",
        "OLLAMA_LOCAL_URL": "${OLLAMA_LOCAL_URL:-http://localhost:11434}",
        "OLLAMA_CLOUD_MODEL": "${OLLAMA_CLOUD_MODEL}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
        "SOUL_ALLOW_WRITE": "true",
        "HF_TOKEN": "${HF_TOKEN}"
      }
    }
  }
}
